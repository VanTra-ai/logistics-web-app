                    }`}
                    value={orderForm.pickup_hub_id}
                    onChange={(e) =>
                      setOrderForm({
                        ...orderForm,
                        pickup_hub_id: e.target.value,
                      })
                    }
                  >
                    <option value="">-- Chọn bưu cục --</option>
                    {hubs.map((h) => (
                      <option key={h.id} value={h.id}>
                        {h.name}
                      </option>
                    ))}
                  </select>
                </div>
              </div>

              {/* Package Dimensions */}
              <div className="grid grid-cols-3 gap-4">
