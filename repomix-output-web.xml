                    <td className="px-4 py-3">
                      {v.assigned_shipper ? (
                        <div>
                          <p className="font-semibold text-slate-700">
                            {v.assigned_shipper.full_name}
                          </p>
                          <p className="text-xs text-slate-400">
                            {v.assigned_shipper.phone_number}
