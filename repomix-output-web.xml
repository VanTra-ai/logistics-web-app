                              </div>
                              <div>
                                <span className="font-semibold text-slate-800 block">
                                  {ship.shipper?.full_name || "Chưa phân công"}
                                </span>
                                <span className="text-[10px] text-slate-400">
                                  {ship.shipper?.phone_number || ""}
                                </span>
                              </div>
                            </div>

