                                <td
                                  colSpan={8}
                                  className="py-12 text-center text-slate-400"
                                >
                                  Không tìm thấy chuyến xe nào trong lịch sử.
                                </td>
                              </tr>
                            )}
                          </tbody>
                        </table>
                      </div>
                    </div>

