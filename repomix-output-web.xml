                    <Pagination
                      currentPage={historyPage}
                      totalPages={historyTotalPages}
                      totalItems={filteredHistory.length}
                      itemsPerPage={historyItemsPerPage}
                      onPageChange={setHistoryPage}
                    />
                  </>
                );
              })()}
            </div>
