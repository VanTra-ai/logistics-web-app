                                      <span
                                        className={`inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-bold ${cfg.badgeBg}`}
                                      >
                                        {cfg.badge} {cfg.label}
                                      </span>
                                    </td>
                                    <td className="py-3 px-4 font-semibold text-slate-800">
